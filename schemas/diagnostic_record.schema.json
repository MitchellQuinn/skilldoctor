{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skilldoctor.local/schemas/diagnostic_record.schema.json",
  "title": "SkillDoctor Diagnostic Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "diagnostic_id",
    "category",
    "severity",
    "title",
    "evidence",
    "risk",
    "recommended_fix",
    "patchable",
    "confidence"
  ],
  "properties": {
    "diagnostic_id": {
      "type": "string",
      "pattern": "^SD[0-9]{3}$"
    },
    "category": {
      "type": "string",
      "enum": [
        "invocation_clarity",
        "input_output_contract",
        "preconditions",
        "acceptance_criteria",
        "execution_hazards",
        "instruction_conflicts",
        "security_prompt_injection",
        "tool_permission_risk",
        "context_load_discipline",
        "host_adapter_compatibility",
        "verification_gaps",
        "maintainer_handoff"
      ]
    },
    "severity": {
      "type": "string",
      "enum": ["info", "minor", "major", "critical"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "string",
      "minLength": 1
    },
    "risk": {
      "type": "string",
      "minLength": 1
    },
    "recommended_fix": {
      "type": "string",
      "minLength": 1
    },
    "patchable": {
      "type": "boolean"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}

